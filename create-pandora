#!/bin/bash

#######################################
#                                     #
#         PanDora Pipeline           #
#                                     #
#######################################

##############################################################################
# Author: Nathaniel Cole (nc564@cornell.edu)                                 #
# GitHub: promicrobial (https://github.com/promicrobial)                     #
# Date: 2024-01-12                                                           #
# License: MIT                                                               #
# Version: 1.0.0                                                             #
#                                                                            #
# Description: Main pipeline script for creating the PanDora database.       #
# This script downloads and processes reference genomes from GRCh38, CHM13,  #
# and processes a user-provided pangenome GFA file to create a non-redundant #
# human pangenome database suitable for read alignment and contamination     #
# detection.                                                                 #
#                                                                            #
# The pipeline performs the following steps:                                 #
# 1. Downloads reference genomes (GRCh38, CHM13)                             #
# 2. Processes user-provided HPRC GFA file with PanSieve                     #
# 3. Combines references into a non-redundant database                       #
# 4. Validates the final database                                            #
#                                                                            #
# Dependencies:                                                              #
#   - datasets: NCBI datasets tool for downloading reference genomes         #
#   - pansieve: For processing HPRC GFA files                                #
#   - seqtk: For sequence processing and manipulation                        #
#                                                                            #
# Usage: ./create-pandora [options] -g <hprc_gfa_file>                       #
#   Required parameters:                                                     #
#     -g, --gfa FILE       Path to HPRC GFA file for PanSieve processing     #
#                                                                            #
#   Optional parameters:                                                     #
#     -o, --output DIR     Output directory (default: ./pandora_output)      #
#     -t, --threads NUM    Number of threads (default: 4)                    #
#     -k, --keep-temp     Keep temporary files for debugging                 #
#     -f, --force         Force redownload of existing files                 #
#     -v, --verbose       Enable verbose output                              #
#     -d, --dry-run       Show commands without executing                    #
#     -h, --help          Show this help message                             #
#     --version           Show version information                           #
#                                                                            #
# Citations:                                                                 #
# NCBI Datasets (O'Leary et al., 2024)                                       #
#   - Paper: https://doi.org/10.1038/s41597-024-03571-y                      #
#   - Tool: https://www.ncbi.nlm.nih.gov/datasets/                           #
# PanSieve (For HPRC GFA processing)                                         #
#   - Tool: https://github.com/cpnh/panSieve                                 #
#                                                                            #
# Last updated: 2024-01-12                                                   #
##############################################################################

# Strict error handling
# -e: Exit immediately if a command exits with non-zero status
# -u: Treat unset variables as an error
# -o pipefail: Return value of a pipeline is the status of the last command to exit with a non-zero status
set -euo pipefail

################################################################################
# Global Variables and Settings                                                #
################################################################################

# Get the directory where the script is located
# This helps with relative path resolution
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Script information
NAME="PanDora Database Creator"
VER="1.0.0"

# Required tools for the script to function
TOOLS=("datasets" "wget" "gunzip" "unzip" "seqtk" "sieve")

# Default settings - these can be overridden by command line arguments
REF_DIR="${SCRIPT_DIR}/references"
TEMP_DIR="${SCRIPT_DIR}/temp"
OUTPUT_DIR="${SCRIPT_DIR}/pandora_output"
THREADS=4
FORCE=false
KEEP_TEMP=false
VERBOSE=false
DRY_RUN=false

# User-provided HPRC GFA file (required parameter)
HPRC_GFA_FILE=""

# Reference genome accessions from NCBI
# These are the latest versions as of the script creation date
declare -A REFERENCES=(
    ["GRCh38"]="GCF_000001405.40"
    ["CHM13"]="GCF_009914755.1"
)

# Source utility functions
source "${SCRIPT_DIR}/utils/bash-utils"

################################################################################
# Help and Usage Functions                                                     #
################################################################################

# Function: usage
# Description: Display the help message and exit
# Arguments: None
# Usage: usage
usage() {
    cat << EOF
Usage: $(basename "$0") [options] -g <hprc_gfa_file>

${NAME} v${VER}

This script creates the PanDora database by downloading and processing reference
genomes from GRCh38, CHM13, and processing a user-provided pangenome GFA file with
PanSieve to create a non-redundant human pangenome database suitable for
contamination detection and read alignment.

Required parameters:
    -g, --gfa FILE        Path to HPRC GFA file for PanSieve processing

Optional parameters:
    -o, --output DIR      Output directory (default: ./pandora_output)
    -t, --threads NUM     Number of threads to use (default: 4)
    -f, --force          Force redownload of existing files
    -k, --keep-temp      Keep temporary files for debugging
    -v, --verbose        Enable verbose output
    -d, --dry-run        Show commands without executing them

Help information:
    -h, --help           Display this help message and exit
    --version            Display the script version and exit

Examples:
    # Basic usage with required GFA file
    $(basename "$0") -g /path/to/hprc.gfa
    
    # Custom output directory with 8 threads
    $(basename "$0") -g /path/to/hprc.gfa -o /path/to/output -t 8
    
    # Verbose mode with temporary file retention
    $(basename "$0") -g /path/to/hprc.gfa -v -k
    
    # Force redownload of reference files
    $(basename "$0") -g /path/to/hprc.gfa -f -v

Output:
    The script creates a directory structure containing:
    - references/: Downloaded reference genomes
    - hprc/: Processed HPRC data from PanSieve
    - pandora_db/: Final non-redundant database
    - logs/: Processing logs and statistics

For more information, visit: https://github.com/cpnh/panSieve
EOF
    exit 0
}

# Function: version
# Description: Display the script version and exit
# Arguments: None
# Usage: version
version() {
    echo "${NAME} version ${VER}"
    exit 0
}

################################################################################
# Argument Parsing                                                             #
################################################################################

# Parse command line options using a while loop
# This approach handles both short (-h) and long (--help) options
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage
            ;;
        --version)
            version
            ;;
        -g|--gfa)
            if [[ -z "${2:-}" || "$2" =~ ^- ]]; then
                log_error "HPRC GFA file path required for $1"
                usage
            fi
            HPRC_GFA_FILE="$2"
            shift 2
            ;;
        -o|--output)
            if [[ -z "${2:-}" || "$2" =~ ^- ]]; then
                log_error "Output directory required for $1"
                usage
            fi
            OUTPUT_DIR="$2"
            shift 2
            ;;
        -t|--threads)
            if [[ -z "${2:-}" || "$2" =~ ^- ]]; then
                log_error "Number of threads required for $1"
                usage
            fi
            THREADS="$2"
            # Validate that threads is a positive integer
            if ! [[ "$THREADS" =~ ^[1-9][0-9]*$ ]]; then
                log_error "Threads must be a positive integer"
                exit 1
            fi
            shift 2
            ;;
        -f|--force)
            FORCE=true
            shift
            ;;
        -k|--keep-temp)
            KEEP_TEMP=true
            shift
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        -d|--dry-run)
            DRY_RUN=true
            shift
            ;;
        *)
            log_error "Unknown option: $1"
            usage
            ;;
    esac
done

# Validate required parameters
if [[ -z "$HPRC_GFA_FILE" ]]; then
    log_error "Required parameter missing: HPRC GFA file (-g/--gfa)"
    usage
fi

# Validate that the HPRC GFA file exists and is readable
if [[ ! -f "$HPRC_GFA_FILE" ]]; then
    log_error "HPRC GFA file not found: $HPRC_GFA_FILE"
    exit 1
fi

if [[ ! -r "$HPRC_GFA_FILE" ]]; then
    log_error "HPRC GFA file is not readable: $HPRC_GFA_FILE"
    exit 1
fi

# Convert to absolute path for consistency
HPRC_GFA_FILE=$(realpath "$HPRC_GFA_FILE")

################################################################################
# Directory and Environment Setup                                              #
################################################################################

# Update directory paths based on output directory
REF_DIR="${OUTPUT_DIR}/references"
TEMP_DIR="${OUTPUT_DIR}/temp"
DB_DIR="${OUTPUT_DIR}/pandora_db"
HPRC_DIR="${OUTPUT_DIR}/hprc"
LOGS_DIR="${OUTPUT_DIR}/logs"

################################################################################
# Core Functions                                                               #
################################################################################

# Function: setup_directories
# Description: Creates all necessary directories for the pipeline
# Arguments: None
# Returns: 0 on success, 1 on failure
# Usage: setup_directories
setup_directories() {
    log_info "Setting up directory structure"
    
    # Array of directories to create
    local dirs=("$REF_DIR" "$TEMP_DIR" "$OUTPUT_DIR" "$DB_DIR" "$HPRC_DIR" "$LOGS_DIR")
    
    # Create each directory if it doesn't exist
    for dir in "${dirs[@]}"; do
        if [[ ! -d "$dir" ]]; then
            log_debug "Creating directory: $dir"
            if ! execute mkdir -p "$dir"; then
                log_error "Failed to create directory: $dir"
                return 1
            fi
        else
            log_debug "Directory already exists: $dir"
        fi
    done
    
    log_info "Directory structure created successfully"
    return 0
}

# Function: download_reference
# Description: Downloads and processes a reference genome using NCBI datasets
# Arguments:
#   $1: Reference name (e.g., "GRCh38" or "CHM13")
#   $2: NCBI accession number
# Returns: 0 on success, 1 on failure
# Usage: download_reference "GRCh38" "GCF_000001405.40"
download_reference() {
    local ref_name=$1
    local accession=$2
    local target_file="${REF_DIR}/${ref_name}.fna"
    
    log_info "Processing reference genome: $ref_name (accession: $accession)"
    
    # Skip if reference already exists and we're not forcing download
    if [[ -f "$target_file" && "$FORCE" == "false" ]]; then
        log_info "Reference $ref_name already exists at $target_file"
        return 0
    fi
    
    # Create temporary directory for this specific download
    local temp_dir
    temp_dir=$(mktemp -d "${TEMP_DIR}/${ref_name}.XXXXXX")
    log_debug "Created temporary directory: $temp_dir"
    
    # Download reference using NCBI datasets tool
    # The datasets tool downloads complete genome assemblies
    log_info "Downloading $ref_name from NCBI..."
    if ! execute datasets download genome accession "$accession" \
        --filename "${temp_dir}/${ref_name}.zip"; then
        log_error "Failed to download $ref_name"
        cleanup "$temp_dir"
        return 1
    fi
    
    # Extract the downloaded ZIP archive
    log_info "Extracting $ref_name archive..."
    if ! execute unzip -q "${temp_dir}/${ref_name}.zip" -d "${temp_dir}"; then
        log_error "Failed to extract $ref_name archive"
        cleanup "$temp_dir"
        return 1
    fi
    
    # Find the reference FASTA file in the extracted contents
    # NCBI datasets creates a specific directory structure
    local found_file
    found_file=$(find "$temp_dir" -type f \( -name "*.fna" -o -name "*.fasta" -o -name "*.fa" \) -print -quit)
    
    if [[ -z "$found_file" ]]; then
        log_error "No reference FASTA file found for $ref_name"
        log_debug "Contents of temp directory:"
        if [[ "$VERBOSE" == "true" ]]; then
            find "$temp_dir" -type f
        fi
        cleanup "$temp_dir"
        return 1
    fi
    
    log_debug "Found reference file: $found_file"
    
    # Decompress if the file is gzipped
    if [[ "$found_file" == *.gz ]]; then
        log_info "Decompressing $ref_name..."
        if ! execute gunzip "$found_file"; then
            log_error "Failed to decompress $ref_name"
            cleanup "$temp_dir"
            return 1
        fi
        # Update file path after decompression
        found_file="${found_file%.gz}"
    fi
    
    # Move to final location and rename appropriately
    log_info "Moving reference to final location: $target_file"
    if ! execute mv "$found_file" "$target_file"; then
        log_error "Failed to move $ref_name to final location"
        cleanup "$temp_dir"
        return 1
    fi
    
    # Validate the reference file
    if ! validate_fasta "$target_file"; then
        log_error "Reference file validation failed for $ref_name"
        return 1
    fi
    
    # Clean up temporary directory
    cleanup "$temp_dir"
    
    log_info "Successfully processed reference: $ref_name"
    return 0
}

# Function: process_hprc_gfa
# Description: Processes the user-provided HPRC GFA file using PanSieve
# Arguments: None (uses global HPRC_GFA_FILE variable)
# Returns: 0 on success, 1 on failure
# Usage: process_hprc_gfa
process_hprc_gfa() {
    log_info "Processing HPRC GFA file with PanSieve: $(basename "$HPRC_GFA_FILE")"
    
    # Define output files
    local hprc_fasta="${HPRC_DIR}/sieved-pangenome-dedup.fa"
    local pansieve_log="${LOGS_DIR}/pansieve.log"
    
    # Skip if processed file already exists and we're not forcing reprocessing
    if [[ -f "$hprc_fasta" && "$FORCE" == "false" ]]; then
        log_info "Processed HPRC file already exists: $hprc_fasta"
        return 0
    fi
    
    # Validate the GFA file format
    if ! validate_gfa "$HPRC_GFA_FILE"; then
        log_error "Invalid GFA file format: $HPRC_GFA_FILE"
        return 1
    fi
    
    # Create temporary directory for PanSieve processing
    local temp_dir
    temp_dir=$(mktemp -d "${TEMP_DIR}/pansieve.XXXXXX")
    log_debug "Created temporary directory for PanSieve: $temp_dir"
    
    # Run PanSieve to process the GFA file
    # PanSieve extracts sequences from GFA format and converts to FASTA
    log_info "Running PanSieve on GFA file..."
    log_info "This may take some time depending on the size of the GFA file..."
    
    # PanSieve command - adjust parameters as needed for your specific use case
    # Assuming PanSieve outputs FASTA format from GFA input
    if ! execute sieve \
        --input "$HPRC_GFA_FILE" \
        --output "$HPRC_DIR" \
        --threads "$THREADS" 2>&1; then
        log_error "PanSieve processing failed"
        log_error "Check the log file for details: $pansieve_log"
        cleanup "$temp_dir"
        return 1
    fi
    
    # Validate the output FASTA file
    if ! validate_fasta "$hprc_fasta"; then
        log_error "PanSieve output validation failed"
        cleanup "$temp_dir"
        return 1
    fi
    
    # Log processing statistics
    local seq_count
    seq_count=$(grep -c "^>" "$hprc_fasta" 2>/dev/null || echo "0")
    local file_size
    file_size=$(du -h "$hprc_fasta" | cut -f1)
    
    log_info "PanSieve processing completed successfully"
    log_info "  Output file: $hprc_fasta"
    log_info "  Sequences: $seq_count"
    log_info "  File size: $file_size"
    log_info "  Log file: $pansieve_log"
    
    # Clean up temporary directory
    cleanup "$temp_dir"
    
    return 0
}

# Function: validate_gfa
# Description: Validates that a GFA file is properly formatted
# Arguments:
#   $1: Path to GFA file to validate
# Returns: 0 if valid, 1 if invalid
# Usage: validate_gfa "/path/to/file.gfa"
validate_gfa() {
    local gfa_file=$1
    
    if [[ ! -f "$gfa_file" ]]; then
        log_error "GFA file not found: $gfa_file"
        return 1
    fi
    
    # Check if file is not empty
    if [[ ! -s "$gfa_file" ]]; then
        log_error "GFA file is empty: $gfa_file"
        return 1
    fi
    
    # Check if file has proper GFA format
    # GFA files should contain lines starting with specific record types (H, S, L, P, etc.)
    if ! grep -q "^[HSLPW]" "$gfa_file"; then
        log_error "GFA file doesn't contain valid GFA records: $gfa_file"
        return 1
    fi
    
    # Check for segment records (S lines) which contain the actual sequences
    if ! grep -q "^S" "$gfa_file"; then
        log_error "GFA file doesn't contain segment records (S lines): $gfa_file"
        return 1
    fi
    
    log_debug "GFA file validation passed: $gfa_file"
    return 0
}

# Function: create_combined_database
# Description: Combines all reference genomes into a single non-redundant database
# Arguments: None
# Returns: 0 on success, 1 on failure
# Usage: create_combined_database
create_combined_database() {
    log_info "Creating combined non-redundant database"
    
    local final_db="${DB_DIR}/pandora.fa"
    local hprc_fasta="${HPRC_DIR}/sieved-pangenome-dedup.fa"
    
    # Skip if database already exists and we're not forcing recreation
    if [[ -f "$final_db" && "$FORCE" == "false" ]]; then
        log_info "Combined database already exists: $final_db"
        return 0
    fi
    
    # Find all reference FASTA files (including processed HPRC)
    local fasta_files
    mapfile -t fasta_files < <(find "$REF_DIR" -name "*.fna" -o -name "*.fasta" -o -name "*.fa" 2>/dev/null || true)
    
    # Check if PanSieve deduplicated output exists
    if [[ ! -f "$hprc_fasta" ]]; then
        log_error "PanSieve deduplicated output file not found: $hprc_fasta"
        log_error "Expected location based on PanSieve processing"
        # List available files in HPRC directory for debugging
        if [[ -d "$HPRC_DIR" ]]; then
            log_info "Available files in HPRC directory:"
            find "$HPRC_DIR" -type f -name "*.fa" -o -name "*.fasta" -o -name "*.fna" | while read -r file; do
                log_info "  $(basename "$file")"
            done
        fi
        return 1
    fi
    
    fasta_files+=("$hprc_fasta")

    log_info "Files to combine:"
    for file in "${fasta_files[@]}"; do
        log_info "  $(basename "$file")"
    done

    # Combine all FASTA files
    log_info "Combining reference genomes and HPRC data..."
    {
        for fasta_file in "${fasta_files[@]}"; do
            local ref_name
            # Determine reference name based on file path
            if [[ "$fasta_file" == *"hprc"* ]]; then
                ref_name="HPRC"
            else
                ref_name=$(basename "$fasta_file" | sed 's/\.[^.]*$//')
            fi
            log_debug "Adding reference: $ref_name from $fasta_file"
            
            # Add reference name prefix to sequence headers
            execute sed "s/^>/>$ref_name\_/" "$fasta_file"
        done
    } > "$final_db"
    
    # Validate the combined database was created successfully
    if [[ ! -f "$final_db" || ! -s "$final_db" ]]; then
        log_error "Failed to create combined database or file is empty"
        return 1
    fi
    
    log_info "Successfully created combined database: $final_db"
    return 0
}

# Function: validate_fasta
# Description: Validates that a FASTA file is properly formatted and not empty
# Arguments:
#   $1: Path to FASTA file to validate
# Returns: 0 if valid, 1 if invalid
# Usage: validate_fasta "/path/to/file.fasta"
validate_fasta() {
    local fasta_file=$1
    
    if [[ ! -f "$fasta_file" ]]; then
        log_error "FASTA file not found: $fasta_file"
        return 1
    fi
    
    # Check if file is not empty
    if [[ ! -s "$fasta_file" ]]; then
        log_error "FASTA file is empty: $fasta_file"
        return 1
    fi
    
    # Check if file has proper FASTA format (starts with >)
    if ! head -n 1 "$fasta_file" | grep -q "^>"; then
        log_error "FASTA file doesn't start with header line: $fasta_file"
        return 1
    fi
    
    log_debug "FASTA file validation passed: $fasta_file"
    return 0
}

# Function: generate_summary
# Description: Generates a summary report of the database creation process
# Arguments: None
# Returns: 0 on success
# Usage: generate_summary
generate_summary() {
    log_info "Generating summary report"
    
    local summary_file="${LOGS_DIR}/pandora_summary.txt"
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    {
        echo "PanDora Database Creation Summary"
        echo "================================"
        echo "Generated: $timestamp"
        echo "Script version: $VER"
        echo ""
        echo "Input Files:"
        echo "  HPRC GFA file: $HPRC_GFA_FILE"
        echo ""
        echo "Settings:"
        echo "  Output directory: $OUTPUT_DIR"
        echo "  Threads used: $THREADS"
        echo "  Force download: $FORCE"
        echo "  Keep temp files: $KEEP_TEMP"
        echo ""
        echo "Reference Genomes:"
        for ref_name in "${!REFERENCES[@]}"; do
            local ref_file="${REF_DIR}/${ref_name}.fna"
            if [[ -f "$ref_file" ]]; then
                local file_size
                file_size=$(du -h "$ref_file" | cut -f1)
                local seq_count
                seq_count=$(grep -c "^>" "$ref_file" 2>/dev/null || echo "0")
                echo "  $ref_name: $file_size ($seq_count sequences)"
            fi
        done
        echo ""
        echo "HPRC Data (Processed with PanSieve):"
        local hprc_file="${HPRC_DIR}/sieved-pangenome-dedup.fa"
        if [[ -f "$hprc_file" ]]; then
            local file_size
            file_size=$(du -h "$hprc_file" | cut -f1)
            local seq_count
            seq_count=$(grep -c "^>" "$hprc_file" 2>/dev/null || echo "0")
            echo "  HPRC processed: $file_size ($seq_count sequences)"
        fi
        echo ""
        echo "Final Database:"
        local final_db="${DB_DIR}/pandora.fa"
        if [[ -f "$final_db" ]]; then
            local db_size
            db_size=$(du -h "$final_db" | cut -f1)
            local total_seqs
            total_seqs=$(grep -c "^>" "$final_db" 2>/dev/null || echo "0")
            echo "  Size: $db_size"
            echo "  Total sequences: $total_seqs"
            echo "  Location: $final_db"
        fi
        
    } > "$summary_file"
    
    # Display summary to user
    cat "$summary_file"
    
    log_info "Summary report saved to: $summary_file"
    return 0
}

################################################################################
# Main Pipeline Function                                                       #
################################################################################

# Function: main
# Description: Main pipeline execution function that orchestrates all steps
# Arguments: All command line arguments passed to the script
# Returns: 0 on success, exits with error code on failure
# Usage: main "$@"
main() {
    local start_time
    start_time=$(date +%s)
    
    log_info "Starting ${NAME} v${VER}"
    log_info "Output directory: $OUTPUT_DIR"
    log_info "HPRC GFA file: $HPRC_GFA_FILE"
    log_info "Using $THREADS threads"
    
    # Step 1: Setup directory structure
    if ! setup_directories; then
        log_error "Failed to setup directories"
        exit 1
    fi
    
    # Step 2: Verify all required dependencies are available
    if ! verify_dependencies "${TOOLS[@]}"; then
        log_error "Missing required tools - please install them and try again"
        exit 1
    fi
    
    # Step 3: Download and process reference genomes
    log_info "=== Downloading Reference Genomes ==="
    for ref_name in "${!REFERENCES[@]}"; do
        if ! download_reference "$ref_name" "${REFERENCES[$ref_name]}"; then
            log_error "Failed to process reference: $ref_name"
            exit 1
        fi
    done
    
# Step 4: Process HPRC GFA file with PanSieve
    log_info "=== Processing HPRC GFA File ==="
    if ! process_hprc_gfa; then
        log_error "Failed to process HPRC GFA file"
        exit 1
    fi
    
    # Step 5: Create combined non-redundant database
    log_info "=== Creating Combined Database ==="
    if ! create_combined_database; then
        log_error "Failed to create combined database"
        exit 1
    fi
    
    # Step 6: Generate summary report
    log_info "=== Generating Summary ==="
    generate_summary
    
    # Calculate and display runtime
    local end_time
    end_time=$(date +%s)
    local duration=$((end_time - start_time))
    
    log_info "Pipeline completed successfully in $(format_duration $duration)"
    log_info "Database location: ${DB_DIR}/pandora.fa"
    log_info "Summary report: ${LOGS_DIR}/pandora_summary.txt"
    
    return 0
}

################################################################################
# Cleanup and Error Handling                                                   #
################################################################################

# Function: cleanup_on_exit
# Description: Cleanup function called on script exit
# Arguments: None
# Returns: None
# Usage: Called automatically via trap
cleanup_on_exit() {
    local exit_code=$?
    
    if [[ $exit_code -ne 0 ]]; then
        log_error "Script failed with exit code $exit_code"
        log_error "Check the log files in ${LOGS_DIR} for details"
    fi
    
    # Clean up temporary files unless KEEP_TEMP is true
    if [[ "$KEEP_TEMP" == "false" && -d "$TEMP_DIR" ]]; then
        log_info "Cleaning up temporary files..."
        execute rm -rf "$TEMP_DIR"
    elif [[ "$KEEP_TEMP" == "true" && -d "$TEMP_DIR" ]]; then
        log_info "Keeping temporary files in: $TEMP_DIR"
    fi
    
    # Remove any stale lock files
    local lock_file="${OUTPUT_DIR}/.pandora_lock"
    if [[ -f "$lock_file" ]]; then
        rm -f "$lock_file"
    fi
    
    exit $exit_code
}

# Function: setup_lock
# Description: Creates a lock file to prevent multiple instances
# Arguments: None
# Returns: 0 on success, 1 if another instance is running
# Usage: setup_lock
setup_lock() {
    local lock_file="${OUTPUT_DIR}/.pandora_lock"
    
    # Check if another instance is already running
    if [[ -f "$lock_file" ]]; then
        local pid
        pid=$(cat "$lock_file" 2>/dev/null || echo "unknown")
        
        # Check if the process is still running
        if kill -0 "$pid" 2>/dev/null; then
            log_error "Another instance of PanDora is already running (PID: $pid)"
            log_error "If this is incorrect, remove the lock file: $lock_file"
            return 1
        else
            # Stale lock file from a crashed process
            log_warn "Removing stale lock file from PID $pid"
            rm -f "$lock_file"
        fi
    fi
    
    # Create new lock file with current PID
    echo $ > "$lock_file"
    log_debug "Created lock file: $lock_file (PID: $)"
    
    return 0
}

# Function: signal_handler
# Description: Handles interrupt signals (Ctrl+C, etc.)
# Arguments:
#   $1: Signal number
# Returns: None
# Usage: Called automatically via trap
signal_handler() {
    local signal=$1
    log_warn "Received signal $signal - shutting down gracefully..."
    
    # Kill any background processes started by this script
    local child_pids
    child_pids=$(jobs -p)
    if [[ -n "$child_pids" ]]; then
        log_info "Terminating child processes..."
        kill $child_pids 2>/dev/null || true
        wait
    fi
    
    log_info "Cleanup completed"
    exit 130  # Standard exit code for script terminated by Ctrl+C
}

################################################################################
# Pre-flight Checks                                                           #
################################################################################

# Function: preflight_checks
# Description: Performs comprehensive pre-flight checks before starting pipeline
# Arguments: None
# Returns: 0 on success, 1 on failure
# Usage: preflight_checks
preflight_checks() {
    log_info "Performing pre-flight checks..."
    
    # Check available disk space
    local available_space
    available_space=$(df "$(dirname "$OUTPUT_DIR")" | awk 'NR==2 {print $4}')
    local required_space=$((10 * 1024 * 1024))  # 10GB in KB
    
    if [[ "$available_space" -lt "$required_space" ]]; then
        log_warn "Low disk space detected. Available: $(($available_space / 1024 / 1024))GB, Recommended: 10GB+"
        log_warn "Pipeline may fail if disk space is insufficient"
    fi
    
    # Check memory availability
    if command -v free >/dev/null 2>&1; then
        local available_mem
        available_mem=$(free -m | awk 'NR==2{print $7}')
        local recommended_mem=4096  # 4GB in MB
        
        if [[ "$available_mem" -lt "$recommended_mem" ]]; then
            log_warn "Low memory detected. Available: ${available_mem}MB, Recommended: 4096MB+"
            log_warn "Consider reducing thread count or running on a system with more memory"
        fi
    fi
    
    # Validate thread count against system capabilities
    if command -v nproc >/dev/null 2>&1; then
        local max_threads
        max_threads=$(nproc)
        if [[ "$THREADS" -gt "$max_threads" ]]; then
            log_warn "Thread count ($THREADS) exceeds available CPU cores ($max_threads)"
            log_warn "Performance may be suboptimal"
        fi
    fi
    
    # Check for required tools with version information
    log_info "Verifying tool versions..."
    for tool in "${TOOLS[@]}"; do
        if command -v "$tool" >/dev/null 2>&1; then
            local version_info
            case "$tool" in
                "datasets")
                    version_info=$(datasets --version 2>&1 | head -n1)
                    ;;
                "sieve")
                    version_info=$(sieve --version 2>&1 | head -n1 || echo "version unknown")
                    ;;
                *)
                    version_info="available"
                    ;;
            esac
            log_debug "$tool: $version_info"
        fi
    done
    
    log_info "Pre-flight checks completed"
    return 0
}

# Function: validate_inputs
# Description: Validates all input parameters and files
# Arguments: None
# Returns: 0 on success, 1 on failure
# Usage: validate_inputs
validate_inputs() {
    log_info "Validating input parameters..."
    
    # Validate HPRC GFA file more thoroughly
    log_info "Validating HPRC GFA file..."
    if ! validate_gfa "$HPRC_GFA_FILE"; then
        return 1
    fi
    
    # Check GFA file size
    local gfa_size
    gfa_size=$(du -h "$HPRC_GFA_FILE" | cut -f1)
    log_info "HPRC GFA file size: $gfa_size"
    
    # Validate output directory is writable
    if [[ ! -w "$(dirname "$OUTPUT_DIR")" ]]; then
        log_error "Cannot write to output directory parent: $(dirname "$OUTPUT_DIR")"
        return 1
    fi
    
    # Validate thread count
    if ! validate_integer "$THREADS" "THREADS"; then
        return 1
    fi
    
    log_info "Input validation completed successfully"
    return 0
}

################################################################################
# Script Execution Entry Point                                                #
################################################################################

# If being sourced, don't execute main
# This allows the script to be imported for testing purposes
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    
    # Set up signal handlers for graceful shutdown
    trap 'signal_handler SIGINT' SIGINT
    trap 'signal_handler SIGTERM' SIGTERM
    
    # Set up cleanup on exit
    trap cleanup_on_exit EXIT
    
    # Validate inputs before starting
    if ! validate_inputs; then
        log_error "Input validation failed"
        exit 1
    fi
    
    # Perform pre-flight checks
    if ! preflight_checks; then
        log_error "Pre-flight checks failed"
        exit 1
    fi
    
    # Setup process lock to prevent multiple instances
    if ! setup_lock; then
        log_error "Failed to acquire process lock"
        exit 1
    fi
    
    # Execute main pipeline function
    main "$@"
fi